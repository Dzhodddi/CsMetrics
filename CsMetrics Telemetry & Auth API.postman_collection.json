    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Encrypted)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Ensure the request was successful",
                  "if (pm.response.code === 200) {",
                  "    try {",
                  "        // 2. Parse the outer response: { \"ciphertext\": \"...\" }",
                  "        var responseData = pm.response.json();",
                  "        ",
                  "        if (responseData.ciphertext) {",
                  "            pm.collectionVariables.set(\"token\", responseData.ciphertext);",
                  "        } else {",
                  "            console.warn(\"No 'ciphertext' field found in the response.\");",
                  "        }",
                  "    } catch (e) {",
                  "        console.error(\"Failed to parse the response or extract the token.\", e);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Client-ID",
                "value": "1",
                "description": "Must match a clientId registered in SessionKeyStore"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "login"
              ]
            },
            "description": "Note: The payload must be an AES-encrypted, Base64-encoded string representing the LoginDto: `{\"username\": \"admin\", \"password\": \"password\"}`."
          },
          "response": []
        }
      ]
    },
